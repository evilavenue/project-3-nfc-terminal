[Unit]
Description=Evil Avenue P3 - OMNY NFC Terminal
After=network.target

[Service]
Type=simple
User=cocozero
WorkingDirectory=/home/cocozero/rfid
ExecStart=/home/cocozero/rfid/venv/bin/python3 /home/cocozero/rfid/omny_server.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
